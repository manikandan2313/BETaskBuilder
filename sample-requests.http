### Soft delete a task (replace 1 with actual task ID)
DELETE {{baseUrl}}/api/taskitems/1

### Try to get a deleted task (should return 404)
GET {{baseUrl}}/api/taskitems/1

### Test concurrency - simulate concurrent update
# 1. Get the task to get current RowVersion
GET {{baseUrl}}/api/taskitems/2

# 2. Update with wrong RowVersion (should return 412)
PUT {{baseUrl}}/api/taskitems/2
Content-Type: {{contentType}}
If-Match: "WrongRowVersionValue"

{
  "title": "This should fail due to concurrency",
  "description": "Testing concurrency handling",
  "priority": "High"
}

### Test validation errors
POST {{baseUrl}}/api/taskitems
Content-Type: {{contentType}}

{
  "title": "",
  "description": "Title is required, this should fail",
  "priority": "InvalidPriority"
}

### Test invalid pagination parameters
GET {{baseUrl}}/api/taskitems?page=0&pageSize=1000

### Test non-existent task
GET {{baseUrl}}/api/taskitems/99999

### Test update non-existent task
PUT {{baseUrl}}/api/taskitems/99999
Content-Type: {{contentType}}
If-Match: "AAAAAAAAB9s="

{
  "title": "This task doesn't exist",
  "priority": "Low"
}
